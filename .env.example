# ── Required: Mealie Connection ──────────────────────────────────────
MEALIE_URL=http://your-mealie-host:9925
MEALIE_API_KEY=your-mealie-api-key-here
MEALIE_SHOPPING_LIST_ID=your-shopping-list-uuid-here

# ── Barcode Lookup Sources ──────────────────────────────────────────
# OpenFoodFacts — free, no key needed, good EU coverage (enabled by default)
# OFF_ENABLED=true
# OFF_URL_BASE=https://world.openfoodfacts.org/api/v2/product/

# UPCDatabase — good US coverage, requires free API key (disabled by default)
# UPCDB_ENABLED=false
# UPCDB_URL_BASE=https://api.upcdatabase.org/product/
# UPCDB_API_KEY=your-upcdatabase-api-key

# ── Lookup Strategy (only relevant when both sources are enabled) ───
# LOOKUP_PRIMARY=off                # Which API is tried first: off | upcdb
# LOOKUP_STRATEGY=failover          # failover  = secondary only when primary finds nothing
#                                   # complement = fill empty brand/qty/type from secondary
# LOOKUP_ENRICH_IN_BACKGROUND=true  # complement: run secondary after ESP32 response (faster)

# ── Matching & Sync ─────────────────────────────────────────────────
# FUZZY_MATCH_THRESHOLD=85          # Min score (0–100) to auto-link a barcode to a Mealie item
# FUZZY_AMBIGUITY_GAP=10            # Min gap between top two matches to prevent false positives
# ITEM_SYNC_INTERVAL_HOURS=6        # How often to re-sync the Mealie food catalog
# LOOKUP_TTL_DAYS=30                # Days before retrying a failed external lookup
# MAX_RETRY_ATTEMPTS=10             # Max retries for failed Mealie shopping list additions

# ── Home Assistant ───────────────────────────────────────────────────
# HA_WEBHOOK_URL=http://homeassistant.local:8123/api/webhook/barcode-scanner
# MIDDLEWARE_BASE_URL=http://192.168.1.100:9930  # For deep links in HA notifications

# ── System ──────────────────────────────────────────────────────────
# TIMEZONE=Europe/Berlin            # IANA timezone for UI timestamps
# SESSION_MAX_AGE_DAYS=7            # How long "Stay signed in" sessions last
# DB_PATH=/data/barcode.db          # SQLite database path (inside container)
# PORT=8000                         # HTTP listen port (inside container)
# LOG_LEVEL=INFO                    # DEBUG, INFO, WARNING, ERROR

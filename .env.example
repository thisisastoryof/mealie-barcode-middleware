# === Required ===
MEALIE_URL=http://your-mealie-host:9925
MEALIE_API_KEY=your-mealie-api-key-here
MEALIE_SHOPPING_LIST_ID=your-shopping-list-uuid-here

# === Optional ===
# OpenFoodFacts (enabled by default)
# OFF_ENABLED=true
# OFF_URL_BASE=https://world.openfoodfacts.org/api/v2/product/

# UPCDatabase (disabled by default — set both UPCDB_ENABLED=true and an API key to activate)
# UPCDB_ENABLED=false
# UPCDB_URL_BASE=https://api.upcdatabase.org/product/
# UPCDB_API_KEY=your-upcdatabase-api-key

# Sync & matching
# FOOD_SYNC_INTERVAL_HOURS=6
# FUZZY_MATCH_THRESHOLD=85
# LOOKUP_TTL_DAYS=30

# Database
# DB_PATH=/data/barcode.db

# Server
# PORT=8000
# LOG_LEVEL=INFO

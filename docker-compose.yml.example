services:
  mealie-barcode-middleware:
    build: .
    image: mealie-barcode-middleware:latest
    restart: unless-stopped
    ports:
      - "9930:8000"
    volumes:
      - ./middleware-data:/data
    env_file:
      - .env
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]
      interval: 30s
      timeout: 5s
      start_period: 15s
